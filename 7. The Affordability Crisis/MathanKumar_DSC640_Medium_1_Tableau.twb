    <worksheet name='Affordability across Years for High Cost States'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Affordability for High Cost States</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (child_care_data)' name='federated.1go4r42090dcsv10tc5281ht50bi' />
          </datasources>
          <datasource-dependencies datasource='federated.1go4r42090dcsv10tc5281ht50bi'>
            <column caption='Affordability Score 6To11' datatype='real' name='[AFFORDABILITY_SCORE_6TO11]' role='measure' type='quantitative' />
            <column caption='State Name' datatype='string' name='[STATE_NAME]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column caption='Studyyear' datatype='integer' name='[STUDYYEAR]' role='measure' type='quantitative' />
            <column-instance column='[AFFORDABILITY_SCORE_6TO11]' derivation='Avg' name='[avg:AFFORDABILITY_SCORE_6TO11:qk]' pivot='key' type='quantitative' />
            <column-instance column='[STATE_NAME]' derivation='None' name='[none:STATE_NAME:nk]' pivot='key' type='nominal' />
            <column-instance column='[STUDYYEAR]' derivation='None' name='[none:STUDYYEAR:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1go4r42090dcsv10tc5281ht50bi].[none:STATE_NAME:nk]'>
            <groupfilter count='10' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='AVG([AFFORDABILITY_SCORE_6TO11])' function='order' user:ui-marker='order'>
                <groupfilter function='level-members' level='[none:STATE_NAME:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
              </groupfilter>
            </groupfilter>
          </filter>
          <filter class='quantitative' column='[federated.1go4r42090dcsv10tc5281ht50bi].[none:STUDYYEAR:qk]' included-values='in-range'>
            <min>2017</min>
            <max>2022</max>
