            <column caption='Affordability Score C Bto5' datatype='real' datatype-customized='true' name='[AFFORDABILITY_SCORE_C_BTO5]' role='measure' type='ordinal' />
            <column caption='Affordability C Bto5 Category' datatype='string' name='[Calculation_587790180781903877]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [AFFORDABILITY_SCORE_C_BTO5] &lt; 7 THEN&#10;    &quot;Affordable&quot;&#10;ELSEIF [AFFORDABILITY_SCORE_C_BTO5] &gt;= 7 AND [AFFORDABILITY_SCORE_C_BTO5] &lt; 14 THEN&#10;    &quot;Manageable&quot;&#10;ELSE&#10;    &quot;Expensive&quot;&#10;END' />
            </column>
            <column caption='Onerace A' datatype='real' name='[ONERACE_A]' role='measure' type='quantitative' />
            <column caption='Onerace B' datatype='real' name='[ONERACE_B]' role='measure' type='quantitative' />
